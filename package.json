{
  "name": "vky-saas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "description": "Plataforma SaaS para clínicas médicas con telemedicina",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo db:generate --filter=@vky/database",
    "db:push": "turbo db:push --filter=@vky/database",
    "db:migrate": "turbo db:migrate --filter=@vky/database",
    "db:seed": "turbo db:seed --filter=@vky/database",
    "docker:up": "docker-compose -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.dev.yml down",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
