# ===========================================
# VKY.SaaS - Variables de Entorno
# ===========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vky_saas?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=3001
API_HOST="localhost"
CORS_ORIGIN="http://localhost:3000"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 2FA
TOTP_ISSUER="VKY.SaaS"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICES_MONTHLY="price_..."
STRIPE_PRICES_YEARLY="price_..."

# Twilio (Telemedicine)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_API_KEY="SK..."
TWILIO_API_SECRET="..."
TWILIO_ROOM_CREATE_PERMISSION=true

# Email (SendGrid)
SENDGRID_API_KEY="SG..."
EMAIL_FROM="noreply@vky-saas.com"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_TWILIO_TOKEN=""
