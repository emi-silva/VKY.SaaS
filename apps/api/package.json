{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/cookie": "^10.0.0",
    "@fastify/websocket": "^10.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@prisma/client": "^5.20.0",
    "@vky/shared": "workspace:*",
    "zod": "^3.23.0",
    "bcryptjs": "^2.4.3",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "dotenv": "^16.4.0",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0",
    "@casl/ability": "^6.5.0",
    "twilio": "^5.3.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/speakeasy": "^2.0.10",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "prisma": "^5.20.0",
    "eslint": "^8.57.0"
  }
}
